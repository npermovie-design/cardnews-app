{
  "name": "cardnews-designer",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:build": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.cardnews.designer",
    "productName": "엔퍼 AI 카드뉴스 자동생성기 v1",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/main.js"
    ],
    "extraResources": [],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "gh-pages": "^6.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@supabase/supabase-js": "^2.99.2",
    "@tosspayments/tosspayments-sdk": "^2.6.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "youtube-transcript": "^1.3.0",
    "ytdl-core": "^4.11.5"
  }
}
